{
  "name": "art-gallery-tailwind",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "lint": "eslint .",
    "typecheck": "node -e \"require('node:fs').rmSync('.next/dev/types', { recursive: true, force: true })\" && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p 6006",
    "build-storybook": "CI=1 STORYBOOK_DISABLE_TELEMETRY=1 storybook build",
    "build:image-blurs": "node scripts/build-image-blurs.mjs",
    "prepare": "husky",
    "build": "next build --webpack",
    "start": "next start",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run build-storybook"
  },
  "dependencies": {
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "resend": "^6.14.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/nextjs-vite": "^10.4.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "latest",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "postcss": "latest",
    "storybook": "^10.4.6",
    "tailwindcss": "^3.4.17",
    "typescript": "latest",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ]
  }
}
